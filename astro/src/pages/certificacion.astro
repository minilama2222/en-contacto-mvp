---
import Base from '../layouts/Base.astro';
import { getContent } from '../utils/content';

const pages = getContent('certificacion');
---

<Base title="Certificación" description="Certificación como Analista Transaccional - ITAA EATA">
  <h1>Certificación como Analista Transaccional</h1>
  
  <p>Información sobre el proceso de certificación en Análisis Transaccional bajo las normas de entrenamiento de la Asociación Europea de Análisis Transaccional (EATA) y de la Asociación Internacional de Análisis Transaccional (ITAA).</p>

  <section class="section">
    <h2>Contenido</h2>
    <div class="grid">
      {pages.map(page => (
        <div class="card">
          <h3><a href={`/certificacion/${page.slug}`}>{page.title}</a></h3>
          <a href={`/certificacion/${page.slug}`} class="btn">Leer más</a>
        </div>
      ))}
    </div>
  </section>
</Base>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1rem;
    margin-top: 1rem;
  }
</style>
