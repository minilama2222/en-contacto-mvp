---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getContent } from "@/utils/content";

const pages = getContent('formacion');
---

<BaseLayout title="Formación" description="Formación profesional en Análisis Transaccional Integrativo">
  <div class="container mx-auto px-4 py-12 max-w-4xl">
    <h1 class="text-3xl font-bold mb-4">Formación</h1>
    <p class="text-lg text-muted-foreground mb-8">
      Formación profesional sólida en Análisis Transaccional y Psicoterapia Integrativa con contenidos teóricos, metodológicos y técnicos.
    </p>

    <ul class="space-y-4">
      {pages.map(page => (
        <li>
          <a href={`/formacion/${page.slug}`} class="block p-4 rounded-lg border hover:bg-accent transition-colors">
            <span class="font-medium">{page.title}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>
