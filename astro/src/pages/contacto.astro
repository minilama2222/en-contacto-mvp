---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getContent } from "@/utils/content";

const pages = getContent('contacto');
const contactarPage = pages.find(p => p.slug.includes('contactar'));
---

<BaseLayout title="Contacto" description="Contactar con el Gabinete de Análisis Transaccional">
  <div class="container mx-auto px-4 py-12 max-w-4xl">
    <h1 class="text-3xl font-bold mb-4">Contacto</h1>
    
    {contactarPage && (
      <div class="prose mb-8" set:html="contactarPage.body" />
    )}

    <h2 class="text-xl font-semibold mb-4">Información legal</h2>
    <ul class="space-y-2">
      {pages.filter(p => p.slug.includes('aviso') || p.slug.includes('politica')).map(page => (
        <li>
          <a href={`/contacto/${page.slug}`} class="text-primary hover:underline">{page.title}</a>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>
