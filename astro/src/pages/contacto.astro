---
import Base from '../layouts/Base.astro';
import { getContent } from '../utils/content';

const pages = getContent('general');
const contactarPage = pages.find(p => p.slug.includes('contactar'));
---

<Base title="Contacto" description="Contactar con el Gabinete de Análisis Transaccional">
  <h1>Contacto</h1>
  
  <section class="section">
    <h2>Gabinete de Análisis Transaccional</h2>
    <p>Centro profesional de Psicología Clínica dedicado desde 1987 a la psicoterapia y la formación.</p>
  </section>

  {contactarPage && (
    <section class="section">
      <div set:html={contactarPage.body} />
    </section>
  )}

  <section class="section">
    <h2>Legal</h2>
    <ul>
      {pages.filter(p => p.slug.includes('politica') || p.slug.includes('aviso')).map(page => (
        <li><a href={`/general/${page.slug}`}>{page.title}</a></li>
      ))}
    </ul>
  </section>
</Base>
