---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getContent } from "../../utils/content";
import { marked } from "marked";

export function getStaticPaths() {
  const categories = ['analisis-transaccional', 'psicoterapia', 'formacion', 'blog', 'contacto', 'inicio', 'general'];
  
  const paths = [];
  const seenSlugs = new Set();
  
  categories.forEach(category => {
    const pages = getContent(category);
    pages.forEach(page => {
      if (!page.slug || seenSlugs.has(page.slug)) return;
      if (/%/.test(page.slug)) return;
      if (page.slug.length > 100) return;
      
      seenSlugs.add(page.slug);
      paths.push({
        params: { categoria: category, slug: page.slug },
        props: { page, category }
      });
    });
  });
  
  return paths;
}

const { page, category } = Astro.props;
const title = page.title || page.slug;
const htmlContent = marked.parse(page.body || '');
---

<BaseLayout title={title} description={page.description}>
  <div class="container mx-auto px-4 py-12 max-w-4xl">
    <a href={`/${category}`} class="text-muted-foreground hover:text-foreground mb-4 inline-block">← Volver</a>
    <h1 class="text-3xl font-bold mb-8">{title}</h1>
    <article class="prose" set:html={htmlContent} />
  </div>
</BaseLayout>
