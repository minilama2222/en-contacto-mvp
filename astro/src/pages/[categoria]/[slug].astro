---
import Base from '../../layouts/Base.astro';
import { getContent, getPage } from '../../utils/content';

export function getStaticPaths() {
  const categories = ['analisis-transaccional', 'formacion', 'psicoterapia', 'certificacion', 'blog', 'gabinete', 'inicio'];
  
  const paths = [];
  
  categories.forEach(category => {
    const pages = getContent(category);
    pages.forEach(page => {
      paths.push({
        params: { categoria: category, slug: page.slug },
        props: { page, category }
      });
    });
  });
  
  return paths;
}

const { page, category } = Astro.props;
const title = page.title || page.slug;
---

<Base title={title} description={page.description}>
  <article class="content-page">
    <header class="page-header">
      <a href={`/${category}`} class="back-link">← Volver a {category}</a>
      <h1>{title}</h1>
    </header>
    
    <div class="page-content" set:html={page.body} />
  </article>
</Base>

<style>
  .content-page {
    max-width: 800px;
    margin: 0 auto;
  }
  
  .page-header {
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid #eee;
  }
  
  .back-link {
    font-size: 0.9rem;
    color: #666;
    text-decoration: none;
  }
  
  .back-link:hover {
    text-decoration: underline;
  }
  
  .page-content :global(h1),
  .page-content :global(h2),
  .page-content :global(h3) {
    margin-top: 2rem;
    margin-bottom: 1rem;
  }
  
  .page-content :global(p) {
    margin: 1rem 0;
    line-height: 1.8;
  }
  
  .page-content :global(ul),
  .page-content :global(ol) {
    margin: 1rem 0;
    padding-left: 2rem;
  }
  
  .page-content :global(li) {
    margin: 0.5rem 0;
  }
  
  .page-content :global(a) {
    color: var(--color-primary);
  }
  
  .page-content :global(blockquote) {
    border-left: 4px solid var(--color-secondary);
    padding-left: 1rem;
    margin: 1rem 0;
    font-style: italic;
    color: #666;
  }
  
  .page-content :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 1rem 0;
  }
  
  .page-content :global(strong) {
    font-weight: 600;
  }
</style>
