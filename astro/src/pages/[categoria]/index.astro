---
import Base from '../../layouts/Base.astro';
import { getContent } from '../../utils/content';

export function getStaticPaths() {
  const categories = ['analisis-transaccional', 'psicoterapia', 'formacion', 'blog', 'contacto', 'inicio', 'general'];
  
  return categories.map(category => ({
    params: { categoria: category },
    props: { category }
  }));
}

const { category } = Astro.props;
const pages = getContent(category);

const categoryTitles = {
  'analisis-transaccional': 'Análisis Transaccional',
  'psicoterapia': 'Psicoterapia',
  'formacion': 'Formación',
  'blog': 'Blog',
  'contacto': 'Contacto',
  'inicio': 'Inicio',
  'general': 'Otros'
};

const categoryDescriptions = {
  'analisis-transaccional': 'Teoría de la personalidad y las relaciones humanas',
  'psicoterapia': 'Servicios de psicoterapia y crecimiento personal',
  'formacion': 'Formación profesional y certificación en AT',
  'blog': 'Artículos sobre desarrollo personal y growth',
  'contacto': 'Información de contacto y legal',
  'inicio': 'Página principal',
  'general': 'Recursos adicionales'
};

const title = categoryTitles[category] || category;
const description = categoryDescriptions[category] || '';
---

<Base title={title} description={description}>
  <article class="list-page">
    <header class="list-header">
      <h1>{title}</h1>
      <p class="description">{description}</p>
    </header>
    
    <ul class="page-list">
      {pages.map(page => (
        <li>
          <a href={`/${category}/${page.slug}`}>
            <span class="page-title">{page.title || page.slug}</span>
          </a>
        </li>
      ))}
    </ul>
    
    {pages.length === 0 && (
      <p class="empty">No hay contenido en esta sección todavía.</p>
    )}
  </article>
</Base>

<style>
  .list-page {
    max-width: var(--width-content);
  }
  
  .list-header {
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--color-border);
  }
  
  h1 {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-sm);
  }
  
  .description {
    font-family: var(--font-body);
    color: var(--color-text-secondary);
  }
  
  .page-list {
    list-style: none;
    padding: 0;
  }
  
  .page-list li {
    border-bottom: 1px solid var(--color-border);
  }
  
  .page-list a {
    display: block;
    padding: var(--space-md) 0;
    text-decoration: none;
    color: var(--color-text);
  }
  
  .page-list a:hover {
    color: var(--color-text-secondary);
  }
  
  .page-title {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 500;
  }
  
  .empty {
    color: var(--color-text-secondary);
    font-style: italic;
  }
</style>
