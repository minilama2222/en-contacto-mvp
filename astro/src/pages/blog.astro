---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getContent } from "@/utils/content";

const pages = getContent('blog');
---

<BaseLayout title="Blog" description="Artículos sobre Análisis Transaccional, psicoterapia y desarrollo personal">
  <div class="container mx-auto px-4 py-12 max-w-4xl">
    <h1 class="text-3xl font-bold mb-4">Blog</h1>
    <p class="text-lg text-muted-foreground mb-8">
      Artículos sobre Análisis Transaccional, psicoterapia integrativa, desarrollo personal y crecimiento emocional.
    </p>

    <ul class="space-y-4">
      {pages.map(page => (
        <li>
          <a href={`/blog/${page.slug}`} class="block p-4 rounded-lg border hover:bg-accent transition-colors">
            <span class="font-medium">{page.title}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>
