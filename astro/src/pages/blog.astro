---
import Base from '../layouts/Base.astro';
import { getContent } from '../utils/content';

const pages = getContent('blog');
---

<Base title="Blog" description="Artículos sobre Análisis Transaccional, psicoterapia y desarrollo personal">
  <h1>Blog</h1>
  
  <p>Artículos sobre Análisis Transaccional, psicoterapia integrativa, desarrollo personal y crecimiento emocional.</p>

  <section class="section">
    <h2>Artículos</h2>
    <div class="grid">
      {pages.map(page => (
        <div class="card">
          <h3><a href={`/blog/${page.slug}`}>{page.title}</a></h3>
          <a href={`/blog/${page.slug}`} class="btn">Leer más</a>
        </div>
      ))}
    </div>
  </section>
</Base>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1rem;
    margin-top: 1rem;
  }
</style>
