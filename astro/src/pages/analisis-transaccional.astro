---
import Base from '../layouts/Base.astro';
import { getContent } from '../utils/content';

const pages = getContent('analisis-transaccional');
---

<Base title="Análisis Transaccional" description="Teoría de la personalidad y las relaciones humanas">
  <article class="section-page">
    <header class="section-header">
      <h1>Análisis Transaccional</h1>
      <p>El Análisis Transaccional es una teoría de la personalidad y de las relaciones humanas que permite comprender cómo pensamos, sentimos y actuamos.</p>
    </header>

    <ul class="page-list">
      {pages.map(page => (
        <li>
          <a href={`/analisis-transaccional/${page.slug}`}>
            <span class="page-title">{page.title}</span>
          </a>
        </li>
      ))}
    </ul>
  </article>
</Base>

<style>
  .section-page {
    max-width: var(--width-content);
  }
  
  .section-header {
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--color-border);
  }
  
  h1 {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-sm);
  }
  
  .section-header p {
    font-family: var(--font-body);
    color: var(--color-text-secondary);
    line-height: 1.6;
  }
  
  .page-list {
    list-style: none;
    padding: 0;
  }
  
  .page-list li {
    border-bottom: 1px solid var(--color-border);
  }
  
  .page-list a {
    display: block;
    padding: var(--space-md) 0;
    text-decoration: none;
    color: var(--color-text);
  }
  
  .page-list a:hover {
    color: var(--color-text-secondary);
  }
  
  .page-title {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 500;
  }
</style>
