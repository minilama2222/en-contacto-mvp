---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getContent } from "@/utils/content";

const pages = getContent('analisis-transaccional');
---

<BaseLayout title="Análisis Transaccional" description="Teoría de la personalidad y las relaciones humanas">
  <div class="container mx-auto px-4 py-12 max-w-4xl">
    <h1 class="text-3xl font-bold mb-4">Análisis Transaccional</h1>
    <p class="text-lg text-muted-foreground mb-8">
      El Análisis Transaccional es una teoría de la personalidad y de las relaciones humanas que permite comprender cómo pensamos, sentimos y actuamos.
    </p>

    <ul class="space-y-4">
      {pages.map(page => (
        <li>
          <a href={`/analisis-transaccional/${page.slug}`} class="block p-4 rounded-lg border hover:bg-accent transition-colors">
            <span class="font-medium">{page.title}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>
