---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getContent } from "@/utils/content";

const blogPages = getContent('blog');
const psicoterapiaPages = getContent('psicoterapia');
const formacionPages = getContent('formacion');
---

<BaseLayout title="Inicio" description="Gabinete de Análisis Transaccional - Psicología Clínica y Formación">
  <div class="container mx-auto px-4 py-16 max-w-4xl">
    <header class="mb-16 text-center">
      <h1 class="text-4xl font-bold mb-4">En Contacto</h1>
      <p class="text-xl text-muted-foreground max-w-2xl mx-auto">
        Gabinete de Análisis Transaccional desde 1987. Psicoterapia individual, de pareja y familia, y formación profesional certificada.
      </p>
    </header>

    <div class="grid md:grid-cols-2 gap-8">
      <a href="/analisis-transaccional" class="block p-6 rounded-lg border hover:bg-accent transition-colors">
        <h2 class="text-xl font-semibold mb-2">Análisis Transaccional</h2>
        <p class="text-muted-foreground">Teoría de la personalidad y las relaciones humanas. Comprende tu manera de pensar, sentir y actuar.</p>
      </a>

      <a href="/psicoterapia" class="block p-6 rounded-lg border hover:bg-accent transition-colors">
        <h2 class="text-xl font-semibold mb-2">Psicoterapia</h2>
        <p class="text-muted-foreground">{psicoterapiaPages.length} artículos sobre el proceso terapéutico y crecimiento personal.</p>
      </a>

      <a href="/formacion" class="block p-6 rounded-lg border hover:bg-accent transition-colors">
        <h2 class="text-xl font-semibold mb-2">Formación</h2>
        <p class="text-muted-foreground">{formacionPages.length} recursos sobre formación profesional y certificación.</p>
      </a>

      <a href="/blog" class="block p-6 rounded-lg border hover:bg-accent transition-colors">
        <h2 class="text-xl font-semibold mb-2">Blog</h2>
        <p class="text-muted-foreground">Artículos sobre desarrollo personal, relaciones y growth profesional.</p>
      </a>
    </div>
  </div>
</BaseLayout>
