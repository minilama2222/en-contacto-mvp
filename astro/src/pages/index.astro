---
import Base from '../layouts/Base.astro';
import { getContent, getCategories } from '../utils/content';

const categories = getCategories();
const blogPages = getContent('blog');
const psicoterapiaPages = getContent('psicoterapia');
const formacionPages = getContent('formacion');
const atPages = getContent('analisis-transaccional');
---

<Base title="Inicio" description="Gabinete de Análisis Transaccional - Psicología Clínica y Formación">
  <section class="intro">
    <h1>En Contacto</h1>
    <p class="subtitle">Gabinete de Análisis Transaccional desde 1987. Psicoterapia individual, de pareja y familia, y formación profesional certificada.</p>
  </section>

  <section class="section">
    <h2>Análisis Transaccional</h2>
    <p>Teoría de la personalidad y las relaciones humanas. Comprende tu manera de pensar, sentir y actuar para crecer y cambiar.</p>
    <a href="/analisis-transaccional">Explorar →</a>
  </section>

  <section class="section">
    <h2>Psicoterapia</h2>
    <p>{psicoterapiaPages.length} artículos sobre el proceso terapéutico, reglas de terapia y trabajo personal.</p>
    <a href="/psicoterapia">Saber más →</a>
  </section>

  <section class="section">
    <h2>Formación</h2>
    <p>{formacionPages.length} recursos sobre formación profesional en Análisis Transaccional y certificación.</p>
    <a href="/formacion">Ver formación →</a>
  </section>

  <section class="section">
    <h2>Blog</h2>
    <p>Artículos sobre desarrollo personal, relaciones y growth profesional.</p>
    <a href="/blog">Leer blog →</a>
  </section>
</Base>

<style>
  .intro {
    margin-bottom: var(--space-2xl);
    padding-bottom: var(--space-2xl);
    border-bottom: 1px solid var(--color-border);
  }
  
  h1 {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: var(--space-md);
  }
  
  .subtitle {
    font-family: var(--font-body);
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    max-width: 540px;
  }
  
  .section {
    margin-bottom: var(--space-2xl);
  }
  
  h2 {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: var(--space-sm);
  }
  
  .section p {
    font-family: var(--font-body);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-sm);
  }
  
  .section a {
    font-family: var(--font-heading);
    font-size: 0.875rem;
    color: var(--color-text);
    text-decoration: none;
  }
  
  .section a:hover {
    text-decoration: underline;
  }
</style>
