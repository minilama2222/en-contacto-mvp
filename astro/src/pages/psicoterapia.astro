---
import Base from '../layouts/Base.astro';
import { getContent } from '../utils/content';

const pages = getContent('psicoterapia');
---

<Base title="Psicoterapia" description="Servicios de psicoterapia individual, de pareja y familia - Análisis Transaccional Integrativo">
  <h1>Psicoterapia</h1>
  
  <p>Centro profesional de Psicología Clínica dedicado desde 1987 principalmente a la psicoterapia individual y en grupo, de pareja y de familia.</p>

  <section class="section">
    <h2>Servicios</h2>
    <div class="grid">
      {pages.map(page => (
        <div class="card">
          <h3><a href={`/psicoterapia/${page.slug}`}>{page.title}</a></h3>
          <a href={`/psicoterapia/${page.slug}`} class="btn">Más información</a>
        </div>
      ))}
    </div>
  </section>

  <section class="section">
    <h2>Contacto</h2>
    <p>Si deseas más información o solicitar una primera sesión, puedes contactarnos.</p>
    <a href="/contacto" class="btn">Contactar</a>
  </section>
</Base>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1rem;
    margin-top: 1rem;
  }
</style>
