---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getContent } from "@/utils/content";

const pages = getContent('psicoterapia');
---

<BaseLayout title="Psicoterapia" description="Servicios de psicoterapia individual, de pareja y familia">
  <div class="container mx-auto px-4 py-12 max-w-4xl">
    <h1 class="text-3xl font-bold mb-4">Psicoterapia</h1>
    <p class="text-lg text-muted-foreground mb-8">
      Centro profesional de Psicología Clínica dedicado desde 1987 principalmente a la psicoterapia individual y en grupo, de pareja y familia.
    </p>

    <ul class="space-y-4">
      {pages.map(page => (
        <li>
          <a href={`/psicoterapia/${page.slug}`} class="block p-4 rounded-lg border hover:bg-accent transition-colors">
            <span class="font-medium">{page.title}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>
